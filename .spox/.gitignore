# Spox-generated files
# These files are managed by spox init and should not be committed

# Spec and change templates (generated from spox templates)
/templates/

# Standards directory (legacy, from older spox versions)
/standards/

# Specs directory (legacy, from older spox versions)
/specs/

# Custom rules directory (legacy, removed in v0.8)
/custom/

# Workflow documentation (generated by spox init)
workflow.md

# Interactive setup script (generated by spox init)
setup.sh

# Version lock file SHOULD be committed (tracks project's spox version)
!version.lock
